# Sanity Configuration for Astro/Web
# Copy to .env and fill in your values
# These are also set in Cloudflare Pages dashboard for production

# Sanity project ID (find in sanity.io/manage)
PUBLIC_SANITY_PROJECT_ID=your-project-id

# Sanity dataset name (usually "production")
PUBLIC_SANITY_DATASET=production

# Sanity API version (optional, defaults to 2024-01-01)
PUBLIC_SANITY_API_VERSION=2024-01-01

# Sanity API token (for comment submission - set in Cloudflare as secret)
# Only needed for CF Functions, not for local Astro dev
SANITY_API_TOKEN=

# Content provider selection (optional, defaults to "sanity")
# Options: sanity, mock
# Set to "mock" to build without Sanity dependencies (testing/portability proof)
# CONTENT_PROVIDER=sanity

# Comment system toggle (optional, defaults to true)
# Set to "false" to disable comments (required for static-only hosting)
# When disabled, CommentList and CommentForm render nothing
# PUBLIC_ENABLE_COMMENTS=true
