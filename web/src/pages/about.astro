---
import Layout from '../layouts/Layout.astro'
import { getSiteSettings, imageUrl } from '../lib/content'
import RichText from '../lib/content/RichText.astro'

const settings = await getSiteSettings()
---

<Layout title="About" description={`About ${settings?.ownerName}`}>
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <div class="md:flex gap-12 items-start">
        <!-- Photo -->
        {settings?.ownerPhoto && (
          <div class="md:w-1/3 mb-8 md:mb-0">
            <img
              src={imageUrl(settings.ownerPhoto, { width: 400, height: 500 })}
              alt={settings?.ownerName}
              class="rounded-lg shadow-lg w-full"
            />
          </div>
        )}

        <!-- Bio -->
        <div class="md:w-2/3">
          <h1 class="text-4xl font-bold text-navy mb-2">{settings?.ownerName}</h1>
          <p class="text-ocean font-semibold mb-6">
            {settings?.yearsTeaching} Years Teaching Sailing
          </p>

          {settings?.ownerBio && (
            <div class="prose max-w-none text-gray-700">
              <RichText html={settings.ownerBio.html} />
            </div>
          )}

          {settings?.certifications && settings.certifications.length > 0 && (
            <div class="mt-8">
              <h2 class="font-bold text-navy mb-3">Certifications</h2>
              <ul class="flex flex-wrap gap-2">
                {settings.certifications.map((cert: string) => (
                  <li class="bg-ocean text-white px-4 py-2 rounded-full text-sm">
                    {cert}
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </div>
    </div>
  </section>
</Layout>
