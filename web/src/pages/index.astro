---
import Layout from '../layouts/Layout.astro'
import { getSiteSettings, getCourses, getFeaturedTestimonials, imageUrl } from '../lib/content'

const settings = await getSiteSettings()
const courses = await getCourses()
const testimonials = await getFeaturedTestimonials()
---

<Layout>
  <!-- Hero -->
  <section class="bg-linear-to-b from-navy to-ocean text-white py-20">
    <div class="max-w-6xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">{settings?.siteName}</h1>
      <p class="text-xl md:text-2xl text-sky mb-8">{settings?.tagline}</p>
      <a href="/courses" class="inline-block bg-white text-navy px-8 py-3 rounded-lg font-semibold hover:bg-sand transition">
        View Courses
      </a>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="text-lg text-gray-700 leading-relaxed">
        {settings?.ownerIntro}
      </p>
      <p class="mt-4 font-semibold text-navy">— {settings?.ownerName}</p>
    </div>
  </section>

  <!-- Courses Preview -->
  <section class="bg-gray-50 py-16">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-3xl font-bold text-navy mb-8 text-center">Courses</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {courses.slice(0, 6).map((course: any) => (
          <a href={`/courses/${course.slug}`} class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-lg transition">
            {course.image && (
              <img
                src={imageUrl(course.image, { width: 400, height: 250 })}
                alt={course.title}
                class="w-full h-48 object-cover"
              />
            )}
            <div class="p-4">
              <p class="text-sm text-ocean font-semibold">{course.code}</p>
              <h3 class="text-lg font-bold text-navy">{course.title}</h3>
              <p class="text-sm text-gray-600 mt-1">{course.duration}</p>
              <p class="text-lg font-bold text-ocean mt-2">From ${course.priceFrom}</p>
            </div>
          </a>
        ))}
      </div>
      <div class="text-center mt-8">
        <a href="/courses" class="text-ocean hover:underline font-semibold">View All Courses →</a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  {testimonials.length > 0 && (
    <section class="py-16">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-navy mb-8 text-center">What Students Say</h2>
        <div class="grid md:grid-cols-3 gap-6">
          {testimonials.map((t: any) => (
            <blockquote class="bg-white p-6 rounded-lg shadow-md">
              <p class="text-gray-700 italic">"{t.quote}"</p>
              <footer class="mt-4 text-sm">
                <cite class="font-semibold text-navy not-italic">{t.authorName}</cite>
                {t.courseName && <span class="text-gray-500"> — {t.courseName}</span>}
              </footer>
            </blockquote>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="bg-ocean text-white py-16">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-4">Ready to Learn to Sail?</h2>
      <p class="text-lg mb-8">Start your sailing journey today. No experience required.</p>
      <a href="/courses" class="inline-block bg-white text-ocean px-8 py-3 rounded-lg font-semibold hover:bg-sand transition">
        Browse Courses
      </a>
    </div>
  </section>
</Layout>
