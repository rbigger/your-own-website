---
import Layout from "../layouts/Layout.astro";
import { getSiteSettings } from "../lib/content";

const settings = await getSiteSettings();
---

<Layout title="Contact" description="Get in touch">
  <section class="py-16">
    <div class="max-w-4xl mx-auto px-4">
      <h1 class="text-4xl font-bold text-navy mb-4 text-center">Contact Us</h1>
      <p class="text-lg text-gray-600 text-center mb-12 max-w-2xl mx-auto">
        Have questions? Ready to book? Get in touch and we'll help you get
        started.
      </p>

      <div class="grid md:grid-cols-2 gap-12">
        <!-- Contact Info -->
        <div>
          <h2 class="text-2xl font-bold text-navy mb-6">Get in Touch</h2>

          <div class="space-y-6">
            <div>
              <h3 class="font-semibold text-gray-700 mb-1">Phone</h3>
              <a
                href={`tel:${settings?.phone}`}
                class="text-xl text-ocean hover:underline"
              >
                {settings?.phone}
              </a>
            </div>

            <div>
              <h3 class="font-semibold text-gray-700 mb-1">Email</h3>
              <a
                href={`mailto:${settings?.email}`}
                class="text-xl text-ocean hover:underline"
              >
                {settings?.email}
              </a>
            </div>

            <div>
              <h3 class="font-semibold text-gray-700 mb-1">Location</h3>
              <p class="text-xl">{settings?.location}</p>
            </div>

            {
              settings?.socialLinks && (
                <div>
                  <h3 class="font-semibold text-gray-700 mb-2">Follow Us</h3>
                  <div class="flex gap-4">
                    {settings.socialLinks.instagram && (
                      <a
                        href={settings.socialLinks.instagram}
                        class="text-ocean hover:text-navy"
                        target="_blank"
                        rel="noopener"
                      >
                        Instagram
                      </a>
                    )}
                    {settings.socialLinks.facebook && (
                      <a
                        href={settings.socialLinks.facebook}
                        class="text-ocean hover:text-navy"
                        target="_blank"
                        rel="noopener"
                      >
                        Facebook
                      </a>
                    )}
                    {settings.socialLinks.youtube && (
                      <a
                        href={settings.socialLinks.youtube}
                        class="text-ocean hover:text-navy"
                        target="_blank"
                        rel="noopener"
                      >
                        YouTube
                      </a>
                    )}
                  </div>
                </div>
              )
            }
          </div>
        </div>

        <!-- Contact Form -->
        <div>
          <h2 class="text-2xl font-bold text-navy mb-6">Send a Message</h2>

          <form
            action="https://formspree.io/f/xnjrldzp"
            method="POST"
            class="space-y-4"
          >
            <div>
              <label
                for="name"
                class="block text-sm font-semibold text-gray-700 mb-1"
                >Name</label
              >
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ocean focus:border-transparent"
              />
            </div>

            <div>
              <label
                for="email"
                class="block text-sm font-semibold text-gray-700 mb-1"
                >Email</label
              >
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ocean focus:border-transparent"
              />
            </div>

            <div>
              <label
                for="phone"
                class="block text-sm font-semibold text-gray-700 mb-1"
                >Phone (optional)</label
              >
              <input
                type="tel"
                id="phone"
                name="phone"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ocean focus:border-transparent"
              />
            </div>

            <div>
              <label
                for="message"
                class="block text-sm font-semibold text-gray-700 mb-1"
                >Message</label
              >
              <textarea
                id="message"
                name="message"
                rows="4"
                required
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-ocean focus:border-transparent"
              ></textarea>
            </div>

            <button
              type="submit"
              class="w-full bg-ocean text-white py-3 rounded-lg font-semibold hover:bg-navy transition"
            >
              Send Message
            </button>
          </form>

          <p class="text-sm text-gray-500 mt-4">
            Or call us directly at <a
              href={`tel:${settings?.phone}`}
              class="text-ocean hover:underline">{settings?.phone}</a
            >
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
