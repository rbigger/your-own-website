---
import Layout from '../../layouts/Layout.astro'
import { getCourses, imageUrl } from '../../lib/content'

const courses = await getCourses()
---

<Layout title="Courses" description="ASA sailing courses from beginner to advanced">
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-4xl font-bold text-navy mb-4 text-center">Sailing Courses</h1>
      <p class="text-lg text-gray-600 text-center mb-12 max-w-2xl mx-auto">
        From your first sail to advanced coastal cruising. ASA-certified courses with hands-on instruction.
      </p>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
        {courses.map((course: any) => (
          <a href={`/courses/${course.slug}`} class="bg-white rounded-lg shadow-md overflow-hidden hover:shadow-xl transition group">
            {course.image && (
              <div class="overflow-hidden">
                <img
                  src={imageUrl(course.image, { width: 400, height: 250 })}
                  alt={course.title}
                  class="w-full h-48 object-cover group-hover:scale-105 transition duration-300"
                />
              </div>
            )}
            <div class="p-6">
              <div class="flex items-center justify-between mb-2">
                <span class="text-sm font-semibold text-ocean">{course.code}</span>
                {course.womenOnlyAvailable && (
                  <span class="text-xs bg-pink-100 text-pink-700 px-2 py-1 rounded">Women-Only Available</span>
                )}
              </div>
              <h2 class="text-xl font-bold text-navy mb-2">{course.title}</h2>
              <p class="text-gray-600 text-sm mb-4">{course.summary}</p>
              <div class="flex items-center justify-between text-sm">
                <span class="text-gray-500">{course.duration}</span>
                <span class="text-lg font-bold text-ocean">From ${course.priceFrom}</span>
              </div>
              {course.isBundle && course.priceNote && (
                <p class="text-green-600 text-sm mt-2 font-semibold">{course.priceNote}</p>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
